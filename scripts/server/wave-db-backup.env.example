DB_FILE=/opt/wave-messenger/data/db.json
LOCAL_BACKUP_DIR=/root/deploy-backups/wave-db
RCLONE_CONFIG=/root/.config/rclone/rclone.conf
RCLONE_REMOTE_NAME=gdrive
RCLONE_REMOTE_DIR="Wave Messenger/db-backups"
RETENTION_DAYS=30
MAX_COPY_RETRIES=10
SLEEP_BETWEEN_RETRIES_SECONDS=2
BACKUP_TZ=Asia/Yekaterinburg
LOG_FILE=/var/log/wave-db-backup.log

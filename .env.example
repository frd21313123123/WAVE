PORT=3000
HOST=0.0.0.0
JWT_SECRET=replace_with_min_32_chars_random_secret
COOKIE_SECURE=auto
TRUST_PROXY=1
# Optional: public URL of your deployed app (for log output)
PUBLIC_URL=
# VAPID keys for Web Push notifications (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=replace_with_generated_public_key
VAPID_PRIVATE_KEY=replace_with_generated_private_key
VAPID_EMAIL=mailto:security@example.com
# Optional: Firebase Cloud Messaging for native Android push
FIREBASE_PROJECT_ID=
# Provide either raw JSON or a path to a service account file
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_PATH=
# Optional: custom ICE/TURN config for WebRTC calls
# If ICE_SERVERS_JSON is set, it overrides STUN_URLS/TURN_* completely.
# Example:
# ICE_SERVERS_JSON=[{"urls":["stun:stun.l.google.com:19302"]},{"urls":["turn:turn.example.com:3478?transport=udp","turn:turn.example.com:3478?transport=tcp"],"username":"wave","credential":"replace_me"}]
ICE_SERVERS_JSON=
STUN_URLS=stun:stun.l.google.com:19302
TURN_URLS=
TURN_USERNAME=
TURN_PASSWORD=

